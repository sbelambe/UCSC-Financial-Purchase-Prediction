{
  "builds": [
    {
      "src": "backend/app/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "functions": {
    "backend/app/main.py": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/app/main.py"
    },
    {
      "src": "/health",
      "dest": "/backend/app/main.py"
    },
    {
      "src": "/status",
      "dest": "/backend/app/main.py"
    },
    {
      "src": "/refresh",
      "dest": "/backend/app/main.py"
    },
    {
      "src": "/([^.]+)",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}