# Copy this into .env and fill it in with appropriate values
# DO NOT push your .env file. .env should be kept secret and uncommitted.

# Note: .env is not enough to run the environment locally. 
# You will also need the following credential files:
# - serviceAccountKey.json
# - google-drive-service.json

# FIREBASE CONFIG
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json
GOOGLE_APPLICATION_CREDENTIALS=google-drive-service.json
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
# Set to True for testing without Firestore writes, False for live uploads
MOCK_FIRESTORE=True

# GOOGLE DRIVE CONFIG
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# BIGQUERY CONFIG
BIGQUERY_DATASET=your-project-id

# CHATBOT CONFIG
USE_VERTEX_AI=True
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
